# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/csa_training

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173"]

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# ── LLM Provider (choose ONE) ─────────────────────────────────────────────────
#
# Option 1: Groq — FREE, fastest, recommended
#   Get key at: https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
#
# Option 2: Google Gemini Flash — FREE tier (15 RPM)
#   Get key at: https://aistudio.google.com/app/apikey
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here
# GEMINI_MODEL=gemini-1.5-flash
#
# Option 3: Ollama — 100% local, truly free (needs Ollama installed)
#   Install: https://ollama.com  then run: ollama pull llama3.2
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
